{
  "id": null,
  "uid": "gatestack-overview",
  "title": "GateStack Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["gatestack", "backend"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Requests / sec",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(gatestack_http_requests_total[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 HTTP Duration (ms)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gatestack_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Requests",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(gatestack_http_requests_total)",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "NodeJS Event Loop Lag p99",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(gatestack_nodejs_eventloop_lag_p99_seconds)",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 }
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {}
}
