# GateStack - Backend NestJS / Prisma / BullMQ

NODE_ENV=development
HOST=0.0.0.0
PORT=5000
ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=info
JWT_SECRET=replace_with_minimum_32_char_random_secret
JWT_EXPIRES_IN=1h
ADMIN_EMAIL=admin@gatestack.local
ADMIN_PASSWORD=replace_with_strong_admin_password
METRICS_TOKEN=replace_with_metrics_scrape_token
THROTTLE_TTL=60
THROTTLE_LIMIT=120
PUBLISH_MAX_CVSS=7

# PostgreSQL
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dbname?schema=public

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_redis_password
QUEUE_ENABLED=false
QUEUE_WORKER_ENABLED=false

# GitHub OAuth
GITHUB_CLIENT_ID=Iv23lie9gGghjl2p1eCG
GITHUB_CLIENT_SECRET=4a0f6f7abfbbff29bc3fee5e5ad38088afb74842
GITHUB_CALLBACK_URL=https://gatestack-backend-production.up.railway.app/api/auth/github/callback

# Grafana defaults (docker-compose)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace_with_grafana_password
