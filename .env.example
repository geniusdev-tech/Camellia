## Camellia Shield — Environment Variables
## Copy to .env and fill values for your environment

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_secure_key_for_production

# JWT secret (defaults to SECRET_KEY if not set)
# JWT_SECRET=

# ── Environment ───────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=0
PORT=5000
HOST=127.0.0.1

# Set to 1 when running inside Tauri webview (relaxes CSRF/HTTPS enforcement)
DESKTOP_MODE=0

# ── Session / Cookies ─────────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_HTTPONLY=1
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# For production: set to redis://localhost:6379
# LIMITER_STORAGE=redis://localhost:6379

# ── KMS Provider ─────────────────────────────────────────────────────────────
KMS_PROVIDER=file
# KMS_PROVIDER=aws
# AWS_KMS_KEY_ID=arn:aws:kms:region:account:key/id
# AWS_REGION=us-east-1

# ── Logging / SIEM ────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=audit.log
# SIEM_ENDPOINT=https://siem.example.com/api/logs

# ── Crypto tuning (leave defaults unless benchmarking) ────────────────────────
# ARGON2_TIME_COST=3
# ARGON2_MEMORY_KB=65536
# ARGON2_PARALLELISM=4
# AEAD_ALGO=AESGCM   # or XCHACHA20 (requires pynacl)
