{
  "name": "gatestack-backend-ts",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch nest-src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "prisma:generate": "HOME=/tmp XDG_CACHE_HOME=/tmp PRISMA_ENGINES_CACHE_DIR=/tmp/prisma-engines prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.mjs",
    "lint": "eslint \"nest-src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"nest-src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --check \"{nest-src,test,prisma}/**/*.{ts,js,json,yml,yaml,md}\"",
    "format:write": "prettier --write \"{nest-src,test,prisma}/**/*.{ts,js,json,yml,yaml,md}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.cjs --runInBand"
  },
  "dependencies": {
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.9",
    "@nestjs/core": "^10.4.9",
    "@nestjs/platform-express": "^10.4.9",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.49.1",
    "dotenv": "^16.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.4.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "@types/bcryptjs": "^2.4.6",
    "@nestjs/testing": "^10.4.9",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
