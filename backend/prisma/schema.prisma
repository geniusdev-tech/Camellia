generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReleaseChannel {
  alpha
  beta
  stable
}

enum DeploymentEnv {
  dev
  staging
  prod
}

enum ReleaseStatus {
  draft
  approved
  published
  archived
}

enum UserRole {
  admin
  writer
  reader
}

enum ReactionType {
  like
  insight
  celebrate
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  name         String?
  avatarUrl    String?  @map("avatar_url")
  githubId     String?  @unique @map("github_id")
  githubToken  String?  @map("github_token")
  role         UserRole @default(reader)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  socialPosts         SocialPost[]            @relation("SocialPostAuthor")
  socialReactions     SocialReaction[]
  socialComments      SocialComment[]
  socialBookmarks     SocialBookmark[]
  socialReposts       SocialRepost[]
  communityMembership SocialCommunityMember[]
  githubRepositories  GitHubRepository[]

  @@map("users")
}

model GitHubRepository {
  id            String   @id @default(uuid())
  githubId      Int      @map("github_id")
  userId        String   @map("user_id")
  name          String
  fullName      String   @map("full_name")
  description   String?
  htmlUrl       String   @map("html_url")
  language      String?
  stargazers    Int      @default(0)
  forks         Int      @default(0)
  dbCreatedAt   DateTime @default(now()) @map("db_created_at")
  dbUpdatedAt   DateTime @updatedAt @map("db_updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([githubId])
  @@unique([userId, githubId])
  @@map("github_repositories")
}

model Release {
  id              String         @id @default(uuid())
  packageName     String         @map("package_name")
  packageVersion  String         @map("package_version")
  releaseChannel  ReleaseChannel @default(stable) @map("release_channel")
  deploymentEnv   DeploymentEnv  @default(dev) @map("deployment_env")
  status          ReleaseStatus  @default(draft)
  maxCvss         Float          @default(0) @map("max_cvss")
  complianceScore Float          @default(0) @map("compliance_score")
  riskScore       Float          @default(100) @map("risk_score")
  policyApproved  Boolean        @default(false) @map("policy_approved")
  rollbackOfId    String?        @map("rollback_of_id")
  metadataJson    String?        @map("metadata_json")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  socialPost      SocialPost?

  @@index([packageName, packageVersion])
  @@index([packageName, releaseChannel, status])
  @@unique([packageName, packageVersion])
  @@map("releases")
}

model SocialPost {
  id        String   @id @default(uuid())
  releaseId String   @unique @map("release_id")
  authorId  String?  @map("author_id")
  content   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  release   Release          @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  author    User?            @relation("SocialPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reactions SocialReaction[]
  comments  SocialComment[]
  bookmarks SocialBookmark[]
  reposts   SocialRepost[]

  @@index([createdAt])
  @@map("social_posts")
}

model SocialReaction {
  id           String       @id @default(uuid())
  postId       String       @map("post_id")
  userId       String       @map("user_id")
  reactionType ReactionType @default(like) @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, reactionType])
  @@map("social_reactions")
}

model SocialComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("social_comments")
}

model SocialBookmark {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("social_bookmarks")
}

model SocialRepost {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, createdAt])
  @@map("social_reposts")
}

model SocialCommunity {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  members SocialCommunityMember[]

  @@map("social_communities")
}

model SocialCommunityMember {
  id          String   @id @default(uuid())
  communityId String   @map("community_id")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  community SocialCommunity @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId, createdAt])
  @@map("social_community_members")
}
